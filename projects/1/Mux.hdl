// File name: projects/1/Mux.hdl
/** 
 * Multiplexor:
 * if (sel = 0) out = a, else out = b
 */
CHIP Mux {
    IN a, b, sel;
    OUT out;

    PARTS:
    Not(in=sel, out=notOut);
    And(a=a, b=notOut, out=orOne);
    And(a=b, b=sel, out=orTwo);
    Or(a=orOne, b=orTwo, out=out);
}